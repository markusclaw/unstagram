# Copy to .env.local (gitignored).

# --- Supabase (public; safe to expose, RLS protects data) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Prose provider (server-side secrets) ---
# Which model writes the prose: gemini | openai | anthropic  (default: gemini)
PROSE_PROVIDER=gemini

# Fill the one you're using; keep the others on hand to switch instantly.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides:
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4.1-mini
# ANTHROPIC_MODEL=claude-haiku-4-5

# Server-only — required for the bot API (/api/v1). Set as a Cloudflare secret in prod.
SUPABASE_SERVICE_ROLE_KEY=
